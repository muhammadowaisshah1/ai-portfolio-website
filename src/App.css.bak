/* RESET & GLOBALS */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: 'Inter', sans-serif;
  background: #f7f9fc;
  color: #111;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* MAIN CONTAINER (Mobile-first) */
#root {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: 1.25rem;
}

/* RESPONSIVE TYPOGRAPHY */
h1, h2, h3 {
  font-weight: 700;
  margin-bottom: 1rem;
}

h1 {
  font-size: 2rem; /* mobile */
}

h2 {
  font-size: 1.5rem;
}

p {
  font-size: 1rem;
  color: #444;
}

/* IMPROVED SPACING */
.section {
  margin: 2.5rem 0;
}

/* PROJECT CARD */
.card {
  background: white;
  border-radius: 14px;
  padding: 1.5rem;
  box-shadow: 0 4px 14px rgba(0,0,0,0.08);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  text-align: left;
}

.card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 25px rgba(0,0,0,0.12);
}

/* PROJECT GRID */
.grid {
  display: grid;
  gap: 1.5rem;
  grid-template-columns: 1fr; /* mobile-first */
}

@media (min-width: 768px) {
  .grid {
    grid-template-columns: repeat(2, 1fr); /* tablets */
  }
}

@media (min-width: 1024px) {
  .grid {
    grid-template-columns: repeat(3, 1fr); /* laptops */
  }
}

/* BUTTONS */
button, .btn {
  background: #4f46e5;
  color: white;
  border: none;
  padding: 0.75rem 1.25rem;
  border-radius: 10px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s ease, transform 0.2s ease;
}

button:hover, .btn:hover {
  background: #3730a3;
  transform: translateY(-2px);
}

/* NAVBAR */
.navbar {
  width: 100%;
  padding: 1rem 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav-links {
  display: none;
  gap: 1rem;
}

.hamburger {
  font-size: 2rem;
  cursor: pointer;
}

@media (min-width: 768px) {
  .nav-links {
    display: flex;
  }
  .hamburger {
    display: none;
  }
}

/* FOOTER */
footer {
  margin-top: 3rem;
  padding: 2rem 0;
  text-align: center;
  color: #666;
}

/* LOGO */
.logo {
  height: 60px;
  margin-bottom: 1rem;
}
