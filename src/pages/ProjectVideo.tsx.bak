import { motion } from "framer-motion";
import { useInView } from "framer-motion";
import { useRef, useState } from "react";
import { ExternalLink, X } from "lucide-react";
import { Button } from "@/components/ui/button";
import { Card } from "@/components/ui/card";

// Example video card section only
const ProjectsSection = ({ projects, selectedCategory, isInView }) => {
  const [showVideo, setShowVideo] = useState(false);
  const [currentVideo, setCurrentVideo] = useState(null);

  const handleVideoOpen = (videoUrl) => {
    setCurrentVideo(videoUrl);
    setShowVideo(true);
  };

  const handleVideoClose = () => {
    setShowVideo(false);
    setCurrentVideo(null);
  };

  return (
    <>
      <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
        {projects
          .filter(
            (project) =>
              selectedCategory === "All" ||
              project.category === selectedCategory
          )
          .map((project, index) => (
            <motion.div
              key={index}
              initial={{ opacity: 0, y: 30 }}
              animate={isInView ? { opacity: 1, y: 0 } : {}}
              transition={{ duration: 0.6, delay: index * 0.1 }}
              className="group"
            >
              <Card className="h-full overflow-hidden bg-card/50 backdrop-blur-sm border-primary/20 hover:border-primary/50 transition-all duration-300 hover:shadow-glow hover:-translate-y-1 rounded-xl">
                <div className="relative h-44 sm:h-48 md:h-52 overflow-hidden bg-gradient-to-br from-primary/20 to-accent/20">
                  <img
                    src={project.image}
                    alt={project.title}
                    className="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                  />
                  <div className="absolute inset-0 bg-gradient-to-t from-background/80 to-transparent" />

                  <div className="absolute top-3 right-3">
                    <span className="text-[10px] sm:text-xs px-2 sm:px-3 py-1.5 rounded-full bg-background/90 backdrop-blur-sm border border-primary/30 text-primary font-medium">
                      {project.category}
                    </span>
                  </div>
                </div>

                <div className="p-4 sm:p-5">
                  <h3 className="text-base sm:text-lg font-bold mb-2 text-foreground group-hover:text-primary transition-colors line-clamp-2">
                    {project.title}
                  </h3>

                  <p className="text-xs sm:text-sm text-muted-foreground leading-relaxed mb-3 line-clamp-3">
                    {project.description}
                  </p>

                  <div className="mb-3 p-2.5 rounded-lg bg-primary/5 border border-primary/10">
                    <div className="flex items-center justify-between">
                      <span className="text-[10px] sm:text-xs text-muted-foreground">
                        Impact
                      </span>
                      <span className="text-xs sm:text-sm font-semibold text-primary">
                        {project.metrics}
                      </span>
                    </div>
                  </div>

                  <div className="flex flex-wrap gap-1.5 mb-3">
                    {project.technologies.slice(0, 3).map((tech, i) => (
                      <span
                        key={i}
                        className="text-[10px] sm:text-xs px-2 py-1 rounded-md bg-muted/50 text-foreground"
                      >
                        {tech}
                      </span>
                    ))}
                  </div>

                  {project.video ? (
                    <Button
                      size="sm"
                      variant="ghost"
                      className="w-full text-sm sm:text-base hover:bg-primary/10 group/btn"
                      onClick={() => handleVideoOpen(project.video)}
                    >
                      🎬 Watch Video
                    </Button>
                  ) : project.url ? (
                    <a
                      href={project.url}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      <Button
                        size="sm"
                        variant="ghost"
                        className="w-full text-sm sm:text-base hover:bg-primary/10 group/btn"
                      >
                        <ExternalLink className="w-3 h-3 sm:w-4 sm:h-4 mr-2 group-hover/btn:translate-x-0.5 transition-transform" />
                        View Details
                      </Button>
                    </a>
                  ) : (
                    <Button
                      size="sm"
                      variant="ghost"
                      disabled
                      className="w-full opacity-50"
                    >
                      Coming Soon
                    </Button>
                  )}
                </div>
              </Card>
            </motion.div>
          ))}
      </div>

      {/* Video Popup Modal */}
      {showVideo && (
        <div className="fixed inset-0 bg-black/80 z-50 flex items-center justify-center p-4">
          <div className="relative bg-background rounded-2xl shadow-lg max-w-4xl w-full overflow-hidden">
            <button
              onClick={handleVideoClose}
              className="absolute top-3 right-3 bg-red-500 text-white p-2 rounded-full hover:bg-red-600 transition"
            >
              <X className="w-5 h-5" />
            </button>

            <video
              src={currentVideo}
              controls
              autoPlay
              className="w-full h-auto rounded-b-2xl"
            />
          </div>
        </div>
      )}
    </>
  );
};

export default ProjectsSection;
